# ──────────────── Django ────────────────
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ──────────────── Database ────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/tuitionmedia

# ──────────────── bKash ────────────────
# Sandbox: https://tokenized.sandbox.bka.sh/v1.2.0-beta
# Production: https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
BKASH_USERNAME=your-bkash-username
BKASH_PASSWORD=your-bkash-password

# ──────────────── Nagad ────────────────
# Sandbox: http://sandbox.mynagad.com:10080
# Production: https://api.mynagad.com
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080
NAGAD_MERCHANT_ID=your-nagad-merchant-id
NAGAD_MERCHANT_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
NAGAD_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ──────────────── SMS (OTP) ────────────────
# Options: console (dev) | twilio | bulksmsbd | sslwireless
SMS_BACKEND=console

# Twilio (international, works in BD)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1234567890

# BulkSMSBD (local BD — https://bulksmsbd.net)
BULKSMSBD_API_KEY=your-bulksmsbd-api-key
BULKSMSBD_SENDER_ID=TuitionMD

# SSL Wireless (local BD — https://sslwireless.com)
SSLWIRELESS_USERNAME=your-ssl-username
SSLWIRELESS_PASSWORD=your-ssl-password
SSLWIRELESS_SID=your-ssl-sid

# ──────────────── Anthropic (Guru AI) ────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key

# ──────────────── Gemini AI (Guru assistant) ────────────────
GEMINI_API_KEY=your-google-gemini-api-key

# ──────────────── Render ────────────────
# Set to TRUE on Render to use SQLite fallback (if no DATABASE_URL)
RENDER=FALSE

# ──────────────── CSRF (production) ────────────────
CSRF_TRUSTED_ORIGINS=https://yourdomain.onrender.com,https://yourapp.replit.app
