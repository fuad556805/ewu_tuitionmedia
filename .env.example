# ──────────────── Django ────────────────
SECRET_KEY=your-django-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ──────────────── Database ────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/tuitionmedia

# ──────────────── bKash ────────────────
# Sandbox: https://tokenized.sandbox.bka.sh/v1.2.0-beta
# Production: https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
BKASH_USERNAME=your-bkash-username
BKASH_PASSWORD=your-bkash-password

# ──────────────── Nagad ────────────────
# Sandbox: http://sandbox.mynagad.com:10080
# Production: https://api.mynagad.com
NAGAD_BASE_URL=http://sandbox.mynagad.com:10080
NAGAD_MERCHANT_ID=your-nagad-merchant-id
NAGAD_MERCHANT_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
NAGAD_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# ──────────────── Anthropic (Guru AI) ────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
